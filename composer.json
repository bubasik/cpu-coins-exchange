{
    "name": "yenten-sugar/exchange",
    "description": "Yenten <-> Sugarchain Exchange & Trading Platform (PHP 8.2, API-only, no full nodes)",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.2",
        "bitwasp/bitcoin": "dev-master",
        "predis/predis": "^2.0",
        "phpmailer/phpmailer": "^6.9",
        "vlucas/phpdotenv": "^5.5"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
