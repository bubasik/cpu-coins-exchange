# ============ Application ============
APP_NAME=Yenten-Sugar Exchange
APP_ENV=production
APP_DEBUG=false
APP_URL=https://your-domain.tld
APP_SECRET=change-me-to-64-random-hex-chars

# ============ Database (SQLite) ============
DB_PATH=storage/exchange.sqlite

# ============ Redis ============
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ============ Mail (SMTP) ============
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USER=noreply@your-domain.tld
MAIL_PASSWORD=your-smtp-password
MAIL_FROM=noreply@your-domain.tld
MAIL_FROM_NAME=Yenten-Sugar Exchange

# ============ Yenten (YTN) ============
YTN_API=https://api.yentencoin.info
YTN_XPRV=xprv...your-yenten-master-private-key...
YTN_XPUB=xpub...your-yenten-master-public-key...
YTN_HOT_ADDRESS=Y...
YTN_CONFIRMATIONS=6
YTN_HD_PATH=m/44H/1234H/0H/0/

# ============ Sugarchain (SUGAR) ============
SUGAR_API=https://api.sugarchain.org
SUGAR_XPRV=xprv...your-sugar-master-private-key...
SUGAR_XPUB=xpub...your-sugar-master-public-key...
SUGAR_HOT_ADDRESS=sugar1q...
SUGAR_CONFIRMATIONS=30
SUGAR_HD_PATH=m/44H/408H/0H/0/

# ============ Adventurecoin (ADVC) ============
ADVC_API=https://api2.adventurecoin.quest
ADVC_XPRV=xprv...your-adventurecoin-master-private-key...
ADVC_XPUB=xpub...your-adventurecoin-master-public-key...
ADVC_HOT_ADDRESS=A...
ADVC_CONFIRMATIONS=6
ADVC_HD_PATH=m/44H/1234H/0H/0/

# ============ Trading ============
# Comma-separated list of pairs. Format: BASE/QUOTE
# Buy order pays QUOTE to receive BASE. Sell order pays BASE to receive QUOTE.
TRADE_PAIRS=YTN/SUGAR,YTN/ADVC,SUGAR/ADVC
TRADE_PAIR_DEFAULT=YTN/SUGAR
TRADE_FEE_PERCENT=0.2
TRADE_MIN_AMOUNT=0.001
# Per-pair fee override (optional):
# TRADE_FEE_YTN_SUGAR=0.15

# ============ Exchange (swap) ============
SWAP_FEE_PERCENT=0.5
SWAP_MIN_AMOUNT=0.01
SWAP_RATE_CACHE_TTL=300

# ============ Exchange rates (reference values) ============
# Used by ExchangeService::getCurrentRate() as fallback.
# Cross-pairs (e.g. SUGAR->ADVC) are computed via YTN as bridge.
RATE_YTN_TO_SUGAR=100.0
RATE_YTN_TO_ADVC=1.0
RATE_SUGAR_TO_ADVC=0.01
